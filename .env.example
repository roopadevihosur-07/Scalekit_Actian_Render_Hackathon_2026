# ── Scalekit credentials ───────────────────────────────────────────────
# Found in your Scalekit dashboard → Settings → API Credentials
SCALEKIT_ENVIRONMENT_URL=https://your-org.scalekit.com
SCALEKIT_CLIENT_ID=skc_your_client_id_here
SCALEKIT_CLIENT_SECRET=sks_your_client_secret_here

# ── OAuth redirect URI ─────────────────────────────────────────────────
# Must be registered in Scalekit dashboard → Settings → Redirect URIs
# Dev:        http://localhost:5173/callback
# Production: https://your-domain.com/callback
REDIRECT_URI=http://localhost:5173/callback

# ── Session security ───────────────────────────────────────────────────
# Change this to a long random string in production
SESSION_SECRET=change-this-to-a-random-string-in-production

# ── Server port (Express backend) ─────────────────────────────────────
PORT=3001
