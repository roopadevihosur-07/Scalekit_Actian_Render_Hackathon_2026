# ── Scalekit credentials ───────────────────────────────────────────────
# Found in your Scalekit dashboard → Settings → API Credentials
SCALEKIT_ENVIRONMENT_URL=https://your-org.scalekit.com
SCALEKIT_CLIENT_ID=skc_your_client_id_here
SCALEKIT_CLIENT_SECRET=sks_your_client_secret_here

# ── OAuth redirect URI ─────────────────────────────────────────────────
# Must be registered in Scalekit dashboard → Settings → Redirect URIs
# Dev:        http://localhost:3001/callback
# Production: https://your-domain.onrender.com/callback
REDIRECT_URI=http://localhost:3001/callback

# ── Session security ───────────────────────────────────────────────────
# Change this to a long random string in production (min 32 characters)
SESSION_SECRET=change-this-to-a-random-string-in-production

# ── VectorAI Database ───────────────────────────────────────────────────
# Self-hosted: localhost:6574 (dev) or your-host:6574 (production)
# Cloud: your-vectorai-instance.vectorai.com:6574
VECTORAI_HOST=localhost:6574

# ── Server port (Express backend) ─────────────────────────────────────
PORT=3001

# ── Environment ─────────────────────────────────────────────────────────
# development or production
NODE_ENV=development
